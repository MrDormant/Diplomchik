# Скопируйте в файл .env (в корень репозитория). Файл .env не коммитьте — см. .gitignore
#
# ОБЯЗАТЕЛЬНО задайте вручную (без них приложение не стартует):
#   DATABASE_URL — подключение к PostgreSQL
#   SECRET_KEY     — случайная строка не короче 32 символов (подпись JWT)
#
# Пример генерации секрета в PowerShell:  [guid]::NewGuid().ToString("N") + [guid]::NewGuid().ToString("N")

# На Windows надёжнее 127.0.0.1, чем localhost (избегаете резолва в ::1 у PostgreSQL/SMTP).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/construction_db

SECRET_KEY=CHANGE_ME_PUT_HERE_AT_LEAST_32_RANDOM_CHARACTERS______
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Почта оператора (куда уходят уведомления о новых заявках)
OPERATOR_EMAIL=operator@example.com

# SMTP: для локальной проверки используйте Mailpit (docker-compose) — порт 1025 без TLS
# На Windows надёжнее 127.0.0.1, чем localhost (избегаете ::1).
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@construction.local

# Телефон менеджера (показ на сайте и в письмах)
MANAGER_PHONE=+74951234567

# Упрощённая формула калькулятора: цена за м² (база)
CALC_PRICE_PER_SQM=8500
